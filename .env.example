GITLAB_API_URL=https://gitlab.com/api/v4
GITLAB_AUTH_MODE=oauth

# OAuth mode (recommended)
GITLAB_OAUTH_ACCESS_TOKEN=
GITLAB_OAUTH_CLIENT_ID=
GITLAB_OAUTH_CLIENT_SECRET=
GITLAB_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/oauth/callback
GITLAB_OAUTH_SCOPES=api
# Optional override. By default token store is instance-aware:
# ~/.config/gitlab-mcp/<gitlab-host>/token.json
# GITLAB_OAUTH_TOKEN_STORE_PATH=/home/<user>/.config/gitlab-mcp/gitlab.com/token.json
# Optional callback timeout in milliseconds (default: 180000)
# GITLAB_OAUTH_CALLBACK_TIMEOUT_MS=180000
# Optional inline wait for seamless auth (ms). During this window server waits
# for OAuth completion and retries current tool call automatically (default: 60000).
# Set 0 to disable inline wait and return AUTH_REQUIRED immediately.
# GITLAB_OAUTH_INLINE_WAIT_MS=60000
GITLAB_OAUTH_AUTO_LOGIN=true
GITLAB_OAUTH_OPEN_BROWSER=true

# PAT mode (fallback)
GITLAB_PAT=

# Advanced fallback project resolution
# GITLAB_DEFAULT_PROJECT=group/repo
# GITLAB_AUTO_RESOLVE_PROJECT_FROM_GIT=true

# Module toggles
GITLAB_ISSUES_MODULE_ENABLED=true
GITLAB_LABELS_MODULE_ENABLED=true
GITLAB_MEMBERS_MODULE_ENABLED=true
GITLAB_PROJECTS_MODULE_ENABLED=true
